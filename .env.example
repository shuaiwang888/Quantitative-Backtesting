# A股量化回测平台 - 环境变量示例
# 复制本文件为 .env，填入真实值。.env 已被 .gitignore 排除，不会进版本控制。
#
# ───────────────────────────────────────────────────────────────────
# 部署到 Render 时：
#   1. render.yaml 用 sync: false 配置了敏感变量，不会自动从 .env 拉
#   2. 必须到 Render Dashboard → Environment 手动填 IWENCAI_API_KEY / MINIMAX_API_KEY
#   3. CORS_ORIGIN 改成你的 GitHub Pages URL（https://<user>.github.io）
# ───────────────────────────────────────────────────────────────────

# 必填：问财 OpenAPI Key
IWENCAI_API_KEY=<your_iwencai_api_key>

# 可选：MiniMax 大模型，用于 /api/analyze 复盘
# 当前客户端只支持 Anthropic 兼容协议（POST {base}/v1/messages + x-api-key），
# 所以 BASE_URL 必须以 /anthropic 结尾
MINIMAX_API_KEY=<your_minimax_api_key>
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7
# M3 thinking 模式 + 大 payload 默认 180s
MINIMAX_TIMEOUT=180

# HTTP 服务
# 本地：127.0.0.1:8000
# Render：必须 0.0.0.0:10000（render.yaml 默认值）
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# CORS：允许哪些 origin 调用 /api/*（多个用逗号分隔；* 表示全部）
# 本地：http://localhost:8000
# 部署后改成：https://<user>.github.io
CORS_ORIGIN=http://localhost:8000

# 鉴权（可选；不填则不校验）
# API_KEY=<your_static_api_key>
# API_KEY_HASH=<sha256_of_api_key>

# 限流（每个 IP 在窗口内最多 N 次请求）
RATE_LIMIT=60
RATE_WINDOW=60

# MySQL 持久化（可选；不填则不持久化）
MYSQL_PERSIST_ENABLED=0
MYSQL_AUTO_PERSIST=0
# 方式 A：socket 连接（推荐，macOS 本机）
MYSQL_SOCKET=/tmp/quant_mysql.sock
# 方式 B：TCP 连接
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
MYSQL_USER=<your_mysql_user>
MYSQL_PASSWORD=<your_mysql_password>
MYSQL_DATABASE=quant_backtest

# 寻优
OPTIMIZE_MAX_COMBINATIONS=2000
OPTIMIZE_TIMEOUT_SECONDS=120

# 批量回测
BATCH_MAX_SYMBOLS=100
BATCH_MAX_WORKERS=10
